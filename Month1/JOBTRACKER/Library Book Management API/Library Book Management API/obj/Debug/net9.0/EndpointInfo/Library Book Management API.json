  },
  "components": {
    "schemas": {
      "Book": {
        "required": [
          "author",
          "isbn",
          "title"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "maxLength": 150,
            "minLength": 0,
            "type": "string"
          },
          "author": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "isbn": {
            "maxLength": 13,
            "minLength": 5,
            "type": "string"
          },
          "isAvailable": {
            "type": "boolean"
          },
          "addedDate": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "genre": {
            "$ref": "#/components/schemas/Genre"
          }
        },
        "additionalProperties": false
      },
      "Genre": {
        "enum": [
          0,
          1,
          2,
          3,
          4
        ],
        "type": "integer",
        "format": "int32"
      }
    }
  },
  "tags": [
    {
      "name": "Books"
    }
  ]
}