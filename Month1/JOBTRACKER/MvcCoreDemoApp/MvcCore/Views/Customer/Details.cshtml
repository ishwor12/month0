@model MvcCore.Models.ViewModels.CustomerViewModel

@{
    ViewData["Title"] = "Customer Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Name</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">← Back</a>
    </div>
</div>

<partial name="_Alerts" />

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Email</div>
                <div>@Model.Email</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Phone</div>
                <div>@(Model.Phone ?? "—")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Total Spent (Confirmed)</div>
                <div class="fs-5 fw-bold text-success">
                    $@Model.TotalSpent.ToString("N2")
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header table-dark">
        Recent Orders (@Model.OrderCount total)
    </div>
    <div class="card-body p-0">
        @{
            var recentOrders = ViewBag.RecentOrders as
                IEnumerable<MvcCore.Models.SalesOrder>;
        }
        @if (recentOrders != null && recentOrders.Any())
        {
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>#</th><th>Date</th><th>Status</th><th>Items</th></tr>
                </thead>
                <tbody>
                    @foreach (var o in recentOrders)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Order" asp-action="Details"
                                   asp-route-id="@o.Id">#@o.Id</a>
                            </td>
                            <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                            <td>@o.Status</td>
                            <td>@o.Items.Count item(s)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted p-3 mb-0">No orders yet.</p>
        }
    </div>
</div>