@model IEnumerable<MvcCore.Models.ViewModels.SupplierViewModel>

@{
    ViewData["Title"] = "Suppliers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Suppliers</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Supplier</a>
</div>

<partial name="_Alerts" />

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Search name, contact, email..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Search</button>
        @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
        {
            <a asp-action="Index" class="btn btn-outline-danger ms-1">✕ Clear</a>
        }
    </div>
</form>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Contact</th>
            <th>Email</th>
            <th>Products</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Name</td>
                <td>@(s.ContactName ?? "—")</td>
                <td>@(s.Email ?? "—")</td>
                <td>
                    <span class="badge bg-secondary">@s.ProductCount</span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@s.Id"
                       class="btn btn-sm btn-outline-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@s.Id"
                       class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-action="Delete" asp-route-id="@s.Id"
                          method="post" class="d-inline"
                          onsubmit="return confirm('Delete this supplier?')">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <p>No suppliers found.</p>
    </div>
}