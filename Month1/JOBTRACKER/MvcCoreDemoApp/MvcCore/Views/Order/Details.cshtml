@model MvcCore.Models.ViewModels.OrderViewModel
@using MvcCore.Models.Enums

@{
    ViewData["Title"] = $"Order #{Model.Id}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Order <span class="text-muted">#@Model.Id</span></h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>

<partial name="_Alerts" />

@* Order Header Card *@
<div class="card shadow-sm mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-bold">Order Details</span>
        <span class="badge bg-@Model.StatusBadge fs-6">
            @Model.Status
        </span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="text-muted small">Customer</div>
                <div class="fw-bold">@Model.CustomerName</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Order Date</div>
                <div>@Model.OrderDate.ToString("dd MMM yyyy")</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Status</div>
                <div>
                    <span class="badge bg-@Model.StatusBadge">
                        @Model.Status
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

@* Order Items Table *@
<div class="card shadow-sm mb-3">
    <div class="card-header table-dark">Order Items</div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Unit Price</th>
                    <th>Qty</th>
                    <th class="text-end">Line Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td>$@item.UnitPrice.ToString("0.00")</td>
                        <td>
                            <span class="badge bg-secondary">
                                @item.Quantity
                            </span>
                        </td>
                        <td class="text-end fw-bold">
                            $@item.LineTotal.ToString("0.00")
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-dark">
                <tr>
                    <td colspan="3">
                        <strong>Order Total</strong>
                    </td>
                    <td class="text-end">
                        <strong class="fs-5">
                            $@Model.OrderTotal.ToString("0.00")
                        </strong>
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@* Action Buttons — driven by status *@
<div class="d-flex gap-2">

    @if (Model.Status == OrderStatus.Pending)
    {
        <form asp-action="OrderConfirm" asp-route-id="@Model.Id"
              method="post"
              onsubmit="return confirm('Confirm this order? Stock will be deducted.')">
            @Html.AntiForgeryToken()
            <button class="btn btn-success">
                ✔ Confirm Order
            </button>
        </form>
    }

    @if (Model.Status != OrderStatus.Cancelled)
    {
        <form asp-action="Cancel" asp-route-id="@Model.Id"
              method="post"
              onsubmit="return confirm('Cancel this order?')">
            @Html.AntiForgeryToken()
            <button class="btn btn-danger">
                ✖ Cancel Order
            </button>
        </form>
    }

    @if (Model.Status == OrderStatus.Cancelled)
    {
        <div class="alert alert-secondary mb-0 py-2 px-3">
            This order has been cancelled.
        </div>
    }

</div>