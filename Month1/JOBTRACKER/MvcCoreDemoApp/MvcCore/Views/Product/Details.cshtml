@model MvcCore.Models.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Product Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Name</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id"
           class="btn btn-outline-primary">Edit</a>
        <a asp-action="Index"
           class="btn btn-outline-secondary ms-2">← Back</a>
    </div>
</div>

<partial name="_Alerts" />

<div class="row g-3">

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header table-dark">Product Info</div>
            <div class="card-body">

                <div class="mb-3">
                    <div class="text-muted small">SKU</div>
                    <code class="fs-6">@Model.SKU</code>
                </div>

                <div class="mb-3">
                    <div class="text-muted small">Category</div>
                    <div>@Model.CategoryName</div>
                </div>

                <div class="mb-3">
                    <div class="text-muted small">Supplier</div>
                    <div>@Model.SupplierName</div>
                </div>

                <div class="mb-3">
                    <div class="text-muted small">Price</div>
                    <div class="fs-5 fw-bold text-success">
                        $@Model.Price.ToString("0.00")
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header table-dark">Stock Info</div>
            <div class="card-body">

                <div class="mb-3">
                    <div class="text-muted small">Current Stock</div>
                    @if (Model.IsLowStock)
                    {
                        <span class="badge bg-danger fs-5">
                            @Model.StockQty units ⚠️ Low Stock
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-success fs-5">
                            @Model.StockQty units
                        </span>
                    }
                </div>

                <div class="mb-3">
                    <div class="text-muted small">
                        Low Stock Alert Threshold
                    </div>
                    <div>@Model.LowStockThreshold units</div>
                </div>

                @if (Model.IsLowStock)
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        ⚠️ Stock is below threshold.
                        Consider restocking this product.
                    </div>
                }

            </div>
        </div>
    </div>

</div>

<div class="mt-3">
    <form asp-action="Delete" asp-route-id="@Model.Id"
          method="post" class="d-inline"
          onsubmit="return confirm('Delete this product?')">
        @Html.AntiForgeryToken()
        <button class="btn btn-outline-danger btn-sm">
            🗑️ Delete Product
        </button>
    </form>
</div>